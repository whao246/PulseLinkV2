APP_ENV=local

DATABASE_URL=mysql+pymysql://pulselink:pulselink@mysql:3306/pulselink
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=pulselink
RUN_ANALYSIS_INLINE=false
ARTIFACT_DIR=/tmp/pulselink-artifacts
LOCAL_FILE_ROOT=/app

PDF_MAX_PAGES=120
PDF_MAX_SIZE_MB=50
STEP_TIMEOUT_SECONDS=300
MAX_RETRY_ATTEMPTS=3
ENABLE_VISION=true

JWT_SECRET=change-me

WECHAT_APP_ID=
WECHAT_APP_SECRET=

COS_REGION=ap-guangzhou
COS_BUCKET=pulselink-local
COS_ENDPOINT=http://minio:9000
COS_SECRET_ID=
COS_SECRET_KEY=
UPLOAD_PRESIGN_EXPIRES_SECONDS=900

LLM_API_BASE=https://api.minimax.chat/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M3

VISION_API_BASE=https://api.minimax.chat/v1
VISION_API_KEY=
VISION_MODEL=MiniMax-M3

