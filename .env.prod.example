APP_ENV=prod

DATABASE_URL=mysql+pymysql://pulselink:<password>@<mysql-host>:3306/pulselink
REDIS_URL=redis://:<password>@<redis-host>:6379/0
QUEUE_NAME=pulselink
RQ_JOB_TIMEOUT_SECONDS=1800

API_PORT=8000
API_WORKERS=2
RUN_ANALYSIS_INLINE=false
ARTIFACT_DIR=/tmp/pulselink-artifacts
LOCAL_FILE_ROOT=/app

PDF_MAX_PAGES=120
PDF_MAX_SIZE_MB=50
STEP_TIMEOUT_SECONDS=300
MAX_RETRY_ATTEMPTS=3
ENABLE_VISION=true

JWT_SECRET=<at-least-32-random-characters>

WECHAT_APP_ID=<wechat-mini-program-app-id>
WECHAT_APP_SECRET=<wechat-mini-program-app-secret>

COS_REGION=ap-guangzhou
COS_BUCKET=<cos-bucket>
COS_ENDPOINT=https://<cos-bucket>.cos.ap-guangzhou.myqcloud.com
COS_SECRET_ID=<cos-secret-id>
COS_SECRET_KEY=<cos-secret-key>
UPLOAD_PRESIGN_EXPIRES_SECONDS=900

LLM_API_BASE=https://api.minimax.chat/v1
LLM_API_KEY=<minimax-api-key>
LLM_MODEL=MiniMax-M3
LLM_TIMEOUT_SECONDS=360
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_BACKOFF_SECONDS=1
LLM_RESPONSE_LOG_MAX_CHARS=2000
LLM_REASONING_SPLIT=true

VISION_API_BASE=https://api.minimax.chat/v1
VISION_API_KEY=<minimax-api-key>
VISION_MODEL=MiniMax-M3
