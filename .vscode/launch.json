{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PulseLink API (local Python)",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonPath": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": ["-Xfrozen_modules=off"],
      "module": "uvicorn",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "APP_ENV": "local",
        "DATABASE_URL": "mysql+pymysql://pulselink:pulselink@127.0.0.1:3307/pulselink",
        "REDIS_URL": "redis://127.0.0.1:6379/0",
        "QUEUE_NAME": "pulselink",
        "RQ_JOB_TIMEOUT_SECONDS": "1800",
        "RUN_ANALYSIS_INLINE": "false",
        "LOCAL_FILE_ROOT": "${workspaceFolder}",
        "COS_ENDPOINT": "http://localhost:9000",
        "COS_BUCKET": "pulselink-local"
      },
      "justMyCode": false
    },
    {
      "name": "PulseLink Worker Job (local Python)",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonPath": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": ["-Xfrozen_modules=off"],
      "module": "app.workers.main",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "APP_ENV": "local",
        "DATABASE_URL": "mysql+pymysql://pulselink:pulselink@127.0.0.1:3307/pulselink",
        "REDIS_URL": "redis://127.0.0.1:6379/0",
        "QUEUE_NAME": "pulselink",
        "RQ_WORKER_CLASS": "simple",
        "RQ_JOB_TIMEOUT_SECONDS": "1800",
        "RUN_ANALYSIS_INLINE": "false",
        "LOCAL_FILE_ROOT": "${workspaceFolder}",
        "COS_ENDPOINT": "http://localhost:9000",
        "COS_BUCKET": "pulselink-local"
      },
      "justMyCode": false
    },
    {
      "name": "Attach API in Docker (debugpy)",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "/app/backend"
        }
      ],
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "PulseLink API + Worker (local Python)",
      "configurations": [
        "PulseLink API (local Python)",
        "PulseLink Worker Job (local Python)"
      ]
    }
  ]
}
